---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | FreeApps` : 'FreeApps'}</title>
    <meta name="description" content="Download the best free apps" />
  </head>
  <body class="bg-white dark:bg-gray-900 text-gray-800 dark:text-gray-100">
    <header class="container mx-auto py-4">
      <h1 class="text-2xl font-bold"><a href="/">FreeApps</a></h1>
    </header>
    <main class="container mx-auto p-4">
      <slot />
    </main>
  </body>
</html>
