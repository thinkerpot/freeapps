---
import BaseLayout from '../../layouts/BaseLayout.astro';
const { slug } = Astro.params;
const page = await Astro.glob(`../../content/${slug}.md`);
if (!page[0]) {
  throw new Error('App not found');
}
const { Content, frontmatter } = page[0];
---
<BaseLayout title={frontmatter.title}>
  <h1 class="text-2xl font-bold mb-4">{frontmatter.title}</h1>
  <img src={frontmatter.image} alt={frontmatter.title} class="w-full h-64 object-cover" />
  <p class="mt-2">{frontmatter.description}</p>
  <a href={frontmatter.download_url} class="text-blue-500 underline">Download</a>
  <article class="mt-4">
    <Content />
  </article>
</BaseLayout>
